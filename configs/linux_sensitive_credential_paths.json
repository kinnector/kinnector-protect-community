{
  "description": "Sensitive credentials and configurations monitored on Linux.",
  "paths": [
    ".ssh/", "id_rsa", "id_dsa", "id_ecdsa", "id_ed25519", ".docker/config.json",
    ".npmrc", ".aws/", ".gitconfig", ".git-credentials", ".pypirc", ".pip/",
    ".kube/", "var/run/secrets/kubernetes.io/", "etc/kubernetes/", ".config/gcloud/",
    ".gnupg/", ".cargo/credentials", ".cargo/credentials.toml", ".config/gh/",
    ".gem/credentials", ".vault-token", "etc/shadow", "exodus", ".keyring", "kwallet"
  ]
}
